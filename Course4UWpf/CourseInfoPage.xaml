<Page x:Class="Course4UWpf.CourseInfoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Course4UWpf"
      mc:Ignorable="d" 
      d:DesignHeight="530" d:DesignWidth="800"
      Title="CourseInfoPage">


    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryBrush"    Color="#FFFBC02D"/>
        <SolidColorBrush x:Key="LightBrush"      Color="#FFFFF9C4"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#FFFFFDE7"/>
        <SolidColorBrush x:Key="FieldBrush"      Color="#FFFFF8E1"/>
        <SolidColorBrush x:Key="LabelBrush"      Color="#FF8D6E1E"/>
        <SolidColorBrush x:Key="ValueBrush"      Color="#FF3E2900"/>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource LabelBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,3"/>
        </Style>

        <Style x:Key="FieldCard" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource FieldBrush}"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="BorderBrush"     Value="#FFFFF9C4"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource ValueBrush}"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground"      Value="#3E2900"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="0,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFFFF176"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FFF9A825"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource LabelBrush}"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#FFCD9B00"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="0,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFFFF8E1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FFFFF176"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    <Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <Border Background="{StaticResource BackgroundBrush}" Padding="24,20">
                <StackPanel MaxWidth="420" HorizontalAlignment="Center">

                    <!-- ── Header banner ── -->
                    <Border Background="{StaticResource PrimaryBrush}"
                        CornerRadius="10"
                        Padding="16,14"
                        Margin="0,0,0,16">
                        <StackPanel>

                            <TextBlock x:Name="CourseNameText"
                                   Text="{Binding CourseType}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#3E2900"
                                   TextWrapping="Wrap"/>

                            <TextBlock Text=""
                                   FontSize="13"
                                   Foreground="#7A5000"
                                   Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Instructor & Schedule ── -->
                    <TextBlock Text="INSTRUCTOR &amp; SCHEDULE"
                           Style="{StaticResource SectionLabel}"
                           Margin="0,0,0,8"/>

                    <Border Style="{StaticResource FieldCard}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Teacher" Style="{StaticResource SectionLabel}"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Teacher.FirstName}"  Style="{StaticResource ValueText}"/>
                                <TextBlock Text=" "/>
                                <TextBlock Text="{Binding Teacher.LastName}"  Style="{StaticResource ValueText}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource FieldCard}">
                            <StackPanel>
                                <TextBlock Text="Day" Style="{StaticResource SectionLabel}"/>
                                <TextBlock x:Name="DayText"
                                       Text="{Binding DayInWeek}"
                                       Style="{StaticResource ValueText}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource FieldCard}">
                            <StackPanel>
                                <TextBlock Text="Hours" Style="{StaticResource SectionLabel}"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="StartHourText"
                                           Text="{Binding StartHour}"
                                           Style="{StaticResource ValueText}"/>
                                    <TextBlock Text=" – "
                                           Style="{StaticResource ValueText}"
                                           Foreground="{StaticResource LabelBrush}"/>
                                    <TextBlock x:Name="EndHourText"
                                           Text="{Binding EndHour}"
                                           Style="{StaticResource ValueText}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ── Divider ── -->
                    <Separator Background="#FFE0D0A0" Margin="0,0,0,12"/>

                    <!-- ── Dates & Location ── -->
                    <TextBlock Text="DATES &amp; LOCATION"
                           Style="{StaticResource SectionLabel}"
                           Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource FieldCard}">
                            <StackPanel>
                                <TextBlock Text="Start Date" Style="{StaticResource SectionLabel}"/>
                                <TextBlock x:Name="StartDateText"
                                       Text="{Binding StartDate}"
                                       Style="{StaticResource ValueText}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource FieldCard}">
                            <StackPanel>
                                <TextBlock Text="End Date" Style="{StaticResource SectionLabel}"/>
                                <TextBlock x:Name="EndDateText"
                                       Text="{Binding   EndDate}"
                                       Style="{StaticResource ValueText}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource FieldCard}">
                            <StackPanel>
                                <TextBlock Text="Room" Style="{StaticResource SectionLabel}"/>
                                <TextBlock x:Name="RoomText"
                                       Text="{Binding RoomNumber}"
                                       Style="{StaticResource ValueText}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource FieldCard}">
                            <StackPanel>
                                <TextBlock Text="Price" Style="{StaticResource SectionLabel}"/>
                                <TextBlock x:Name="PriceText"
                                       Text="{Binding Price}"
                                       Style="{StaticResource ValueText}"
                                       FontSize="18"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ── Buttons ── -->
                    <Separator Background="#FFE0D0A0" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                            x:Name="SignButton"
                            Content="Sign Up"
                            Style="{StaticResource PrimaryButton}"
                            Click="SignButton_Click"/>
                        
                        <Button Grid.Column="0"
                            x:Name="deleteButton"
                            Content="delete"
                            Style="{StaticResource PrimaryButton}"
                            Click="DeleteButton_Click"/>
                        

                        <Button Grid.Column="2"
                            x:Name="CancelButton"
                            Content="Cancel"
                            Style="{StaticResource GhostButton}"
                            Click="CancelButton_Click"/>
                    </Grid>

                </StackPanel>

            </Border>
        </ScrollViewer>

        <Frame x:Name="MainFrame"
        NavigationUIVisibility="Hidden" Navigated="MainFrame_Navigated"/>
    </Grid>

</Page>
