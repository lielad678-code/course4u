<Page x:Class="Course4UWpf.CourseWithUserControlPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Course4UWpf"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CourseWithUserControlPage">

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- כותרת עליונה -->
            <RowDefinition Height="*"/>
            <!-- תוכן עליון -->
            <RowDefinition Height="Auto"/>
            <!-- כותרת תחתונה -->
            <RowDefinition Height="*"/>
            <!-- תוכן תחתון -->
        </Grid.RowDefinitions>

        <!-- כותרת עליונה -->
        <TextBlock Grid.Row="0"
               Text="My Courses"
               FontSize="20"
               FontWeight="Bold"
               x:Name="txtMyCourses"
               Margin="10"/>
        
        

        <!-- שורה עליונה עם המידע -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Padding="10">
                <UniformGrid x:Name="gridMyCourses"
                         Columns="3"
                         VerticalAlignment="Top"/>
            </Border>
        </ScrollViewer>

        <!-- כותרת תחתונה -->
        <TextBlock Grid.Row="2"
               Text="Find New Courses"
               FontSize="20"
               FontWeight="Bold"
               x:Name="txtFindNewCourses"
               Margin="10"/>

        <!-- שורה תחתונה (ריקה בינתיים) -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <Border Padding="10">
                <UniformGrid x:Name="gridNewCourses"
                         Columns="3"
                         VerticalAlignment="Top"/>
            </Border>
        </ScrollViewer>

    </Grid>
</Page>
