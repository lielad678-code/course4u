<UserControl x:Class="Course4UWpf.Controls.UserCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Course4UWpf.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="220" d:DesignWidth="300">


    <Border Background="White" CornerRadius="12" Padding="16" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.15"/>
        </Border.Effect>

        <StackPanel>
            <!-- שם התלמיד -->
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding FirstName}" FontSize="18" FontWeight="SemiBold" Margin="0,0,5,0"/>
                <TextBlock Text="{Binding LastName}" FontSize="18" FontWeight="SemiBold"/>
            </StackPanel>

            <Separator Margin="0,10"/>

            <!-- פרטי התלמיד -->
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <TextBlock Text="Email: " Width="80" Foreground="Gray"/>
                    <TextBlock Text="{Binding Email}"/>
                </StackPanel>
            
            <StackPanel Orientation="Vertical">
                


                <!-- מגמות / תחומי עניין -->
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Border Background="#FFE0E0E0" CornerRadius="10" Margin="0,0,5,0">
                        <TextBlock Text="{Binding PhoneNumber}" Margin="8,2" FontSize="11"/>
                    </Border>
                    <Border Background="#FFE0E0E0" CornerRadius="10">
                        <TextBlock Text="{Binding Password}" Margin="8,2" FontSize="11"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>

