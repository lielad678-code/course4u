<UserControl x:Class="Course4UWpf.Controls.CourseCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Course4UWpf.Controls"
             mc:Ignorable="d" 
            d:DesignHeight="220" d:DesignWidth="300">


    <Border Background="White" CornerRadius="12" Padding="16" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.15"/>
        </Border.Effect>

        <StackPanel>
            <!-- שם התלמיד -->
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding CourseType}"  FontSize="18" FontWeight="SemiBold" Margin="0,0,5,0"/>
            </StackPanel>

            <Separator Margin="0,10"/>

            <!-- פרטי התלמיד -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Day -->
                <Border Grid.Row="0" Grid.Column="0"
            Background="#FFFFF8E1" CornerRadius="8" Padding="10,7"
            BorderBrush="#FFFFF9C4" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Day"
                       FontSize="11" FontWeight="SemiBold" Foreground="#FF8D6E1E" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding DayInWeek}"
                       FontSize="14" FontWeight="SemiBold" Foreground="#FF3E2900"/>
                    </StackPanel>
                </Border>

                <!-- Price -->
                <Border Grid.Row="0" Grid.Column="2"
            Background="#FFFFF8E1" CornerRadius="8" Padding="10,7"
            BorderBrush="#FFFFF9C4" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Price"
                       FontSize="11" FontWeight="SemiBold" Foreground="#FF8D6E1E" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding Price}"
                       FontSize="14" FontWeight="SemiBold" Foreground="#FF3E2900"/>
                    </StackPanel>
                </Border>

                <!-- Age -->
                <Border Grid.Row="2" Grid.Column="0"
            Background="#FFFFF8E1" CornerRadius="8" Padding="10,7"
            BorderBrush="#FFFFF9C4" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Age"
                       FontSize="11" FontWeight="SemiBold" Foreground="#FF8D6E1E" Margin="0,0,0,2"/>
                        <TextBlock Text="8"
                       FontSize="14" FontWeight="SemiBold" Foreground="#FF3E2900"/>
                    </StackPanel>
                </Border>

                <!-- Rating -->
                <Border Grid.Row="2" Grid.Column="2"
            Background="#FFFFF8E1" CornerRadius="8" Padding="10,7"
            BorderBrush="#FFFFF9C4" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Rating"
                       FontSize="11" FontWeight="SemiBold" Foreground="#FF8D6E1E" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding Rating}"
                       FontSize="14" FontWeight="SemiBold" Foreground="#FF3E2900"/>
                    </StackPanel>
                </Border>

            </Grid>

            <StackPanel Orientation="Vertical">



                <!-- מגמות / תחומי עניין -->
                <!--<StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Border Background="#FFE0E0E0" CornerRadius="10" Margin="0,0,5,0">
                        <TextBlock Text="{Binding PhoneNumber}" Margin="8,2" FontSize="11"/>
                    </Border>
                    <Border Background="#FFE0E0E0" CornerRadius="10">
                        <TextBlock Text="{Binding Password}" Margin="8,2" FontSize="11"/>
                    </Border>
                </StackPanel>-->
            </StackPanel>
            <Button Content="More info" x:Name="btnMoreInfo" Click="btnMoreInfo_Click"/>
        </StackPanel>
    </Border>
</UserControl>
