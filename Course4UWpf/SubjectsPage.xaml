<Page x:Class="Course4UWpf.SubjectsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Course4UWpf"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SubjectsPage"  Background="#FFE28B8C">
   

    <DataGrid x:Name="SubjectsGrid"
          AutoGenerateColumns="False"
          HeadersVisibility="Column"
          IsReadOnly="True"
          Background="White"
          Foreground="Black"
          Margin="10">
        <DataGrid.Columns>
            <DataGridTextColumn Header="subjects" Binding="{Binding Subjects}" Width="*"/>
            <DataGridTextColumn Header="units" Binding="{Binding Units}" Width="*"/>
        </DataGrid.Columns>
    </DataGrid>
</Page>
