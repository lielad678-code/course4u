<Page x:Class="Course4UWpf.SignNewTeacherPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Course4UWpf"
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="450"
      Title="SignNewTeacherPage">
    
    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#FFFBC02D"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FFFFF176"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#FFFFFDE7"/>

        <Style x:Key="InputBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderBrush" Value="#FFFFF9C4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </Page.Resources>

    <!-- MAIN CARD -->
    <Grid Background="#00FFFFFF">
        <Border CornerRadius="15"
                Background="{StaticResource BackgroundBrush}"
                Margin="20"
                Width="420"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Border.Effect>
                <DropShadowEffect ShadowDepth="0"
                                  BlurRadius="20"
                                  Opacity="0.35"
                                  Color="#444"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="30" Width="350">

                    <!-- Title -->
                    <TextBlock Text="Teacher Registration"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#FBC02D"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Join Course4U as a teacher!"
                               FontSize="13"
                               Foreground="#555"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <!-- Email -->
                    <Label Content="Email*" FontWeight="SemiBold"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <TextBox x:Name="EmailTextBox"
                                 BorderThickness="0"
                                 Padding="8" TextChanged="EmailTextBox_TextChanged"/>
                    </Border>

                    <!-- Password -->
                    <Label Content="Password*" Margin="0,10,0,0" FontWeight="SemiBold"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <PasswordBox x:Name="PasswordBox"
                                     BorderThickness="0"
                                     Padding="8"/>
                    </Border>

                    <!-- First Name -->
                    <Label Content="First Name*" Margin="0,10,0,0" FontWeight="SemiBold"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <TextBox x:Name="FirstNameTextBox"
                                 BorderThickness="0"
                                 Padding="8"/>
                    </Border>

                    <!-- Last Name -->
                    <Label Content="Last Name*" Margin="0,10,0,0" FontWeight="SemiBold"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <TextBox x:Name="LastNameTextBox"
                                 BorderThickness="0"
                                 Padding="8"/>
                    </Border>

                    <!-- Phone -->
                    <Label Content="Phone Number*" Margin="0,10,0,0" FontWeight="SemiBold"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <TextBox x:Name="PhoneNumberTextBox"
                                 BorderThickness="0"
                                 Padding="8"/>
                    </Border>

                    <!-- Expertise -->

                    <!-- Birth Date -->
                    <Label Content="Birth Date*" Margin="0,10,0,0" FontWeight="SemiBold"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <DatePicker x:Name="BirthDatePicker"
                                    BorderThickness="0"
                                    Padding="8"/>
                    </Border>

                    <!-- Gender -->
                    <Label Content="Gender*" Margin="0,10,0,0" FontWeight="SemiBold"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <ComboBox x:Name="GenderComboBox"
                                  BorderThickness="0"
                                  Padding="8">
                            <ComboBoxItem Content="Male"/>
                            <ComboBoxItem Content="Female"/>
                        </ComboBox>
                    </Border>
                    
                    <Label Content="Teaching Course*" Margin="0,10,0,0" FontWeight="SemiBold"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <TextBox x:Name="ExpertiseTextBox"
                                 BorderThickness="0"
                                 Padding="8"/>
                    </Border>
                    
                    
                    <Label Content="Salary*" Margin="0,10,0,0" FontWeight="SemiBold"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <TextBox x:Name="SalaryTextBox"
                                 BorderThickness="0"
                                 Padding="8"/>
                    </Border>
                    <!-- Buttons -->
                    <Button Content="Create Teacher Account"
                            Margin="0,20,0,10"
                            Height="38"
                            Background="{StaticResource PrimaryBrush}"
                            FontWeight="SemiBold"
                            Click="RegisterTeacher_Click"/>

                    <Button Content="Back"
                            Height="38"
                            Background="#AAAAAA"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Click="BackButton_Click"/>

                    <!-- Error -->
                    <TextBlock x:Name="ErrorMessageTextBlock"
                               Foreground="Red"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>


    
</Page>
