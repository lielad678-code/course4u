<Window x:Class="Course4UWpf.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Course4U - Student Registration"
        Height="770" Width="450"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        FontFamily="Segoe UI">

    <!-- 🎨 COLORS AND STYLES -->
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#FFFBC02D"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FFFFF176"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#FFFFFDE7"/>

        <Style x:Key="InputBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderBrush" Value="#FFFFF9C4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="15"
            Background="{StaticResource BackgroundBrush}"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0"
                              BlurRadius="20"
                              Opacity="0.35"
                              Color="#444"/>
        </Border.Effect>

        <Grid>
            <!-- CONTENT -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="30"
                            Width="350"
                            HorizontalAlignment="Center">

                    <!-- Title -->
                    <TextBlock Text="Student Registration"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#FBC02D"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Join Course4U today!"
                               FontSize="13"
                               Foreground="#555"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <!-- Email -->
                    <Label Content="Email*" FontWeight="SemiBold"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <TextBox x:Name="EmailTextBox"
                                 BorderThickness="0"
                                 Padding="8"/>
                    </Border>

                    <!-- Password -->
                    <Label Content="Password*" Margin="0,10,0,0" FontWeight="SemiBold"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <PasswordBox x:Name="PasswordBox"
                                     BorderThickness="0"
                                     Padding="8"/>
                    </Border>

                    <!-- First Name -->
                    <Label Content="First Name*" Margin="0,10,0,0" FontWeight="SemiBold"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <TextBox x:Name="FirstNameTextBox"
                                 BorderThickness="0"
                                 Padding="8"/>
                    </Border>

                    <!-- Last Name -->
                    <Label Content="Last Name*" Margin="0,10,0,0" FontWeight="SemiBold"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <TextBox x:Name="LastNameTextBox"
                                 BorderThickness="0"
                                 Padding="8" TextChanged="LastNameTextBox_TextChanged"/>
                    </Border>

                    <!-- Phone Number (KEPT) -->
                    <Label Content="Parent Phone Number*" Margin="0,10,0,0" FontWeight="SemiBold"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <TextBox x:Name="ParentPhoneNumberTextBox"
                                 BorderThickness="0"
                                 Padding="8"/>
                    </Border>

                    <!-- Birth Date -->
                    <Label Content="Birth Date*" Margin="0,10,0,0" FontWeight="SemiBold"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <DatePicker x:Name="BirthDatePicker"
                                    BorderThickness="0"
                                    Padding="8"/>
                    </Border>

                    <!-- Gender -->
                    <Label Content="Gender*" Margin="0,10,0,0" FontWeight="SemiBold"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <ComboBox x:Name="GenderComboBox"
                                  BorderThickness="0"
                                  Padding="8">
                            <ComboBoxItem Content="Male"/>
                            <ComboBoxItem Content="Female"/>
                        </ComboBox>
                    </Border>

                    <!-- Buttons -->
                    <Button Content="Create Account"
                            Margin="0,20,0,10"
                            Height="38"
                            Background="{StaticResource PrimaryBrush}"
                            FontWeight="SemiBold"
                            Click="RegisterButton_Click"/>

                    <Button x:Name="LoginBtn" Content="Back to Login"
                            Height="38"
                            Background="#AAAAAA"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Click="BackButton_Click"/>

                    <!-- Error -->
                    <TextBlock x:Name="ErrorMessageTextBlock"
                               Foreground="Red"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
