<Window x:Class="Course4UWpf.RegisterStudentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Course4UWpf"
        mc:Ignorable="d"
        Title="Register New Student"
        Height="650"
        Width="525"
        WindowStartupLocation="CenterScreen"
        Background="#FFFFFDE7"
        FontFamily="Segoe UI">
    <Grid Background="#FFFFFDE7">
        <Border CornerRadius="12"
                Background="White"
                Margin="20">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0"
                                  BlurRadius="15"
                                  Opacity="0.3"
                                  Color="#444"/>
            </Border.Effect>

            <StackPanel VerticalAlignment="Center" Margin="30">

                <TextBlock Text="Register New Teacher"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#FFFBC02D"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>


                <Label Content="First Name"/>
                <TextBox x:Name="FirstNameTextBox" Margin="0,0,0,10"/>

                <Label Content="Last Name"/>
                <TextBox x:Name="LastNameTextBox" Margin="0,0,0,10"/>

                <Label Content="Email"/>
                <TextBox x:Name="EmailTextBox" Margin="0,0,0,10"/>

                <Label Content="Password"/>
                <PasswordBox x:Name="PasswordBox" Margin="0,0,0,10"/>

                <Label Content="Birth date"/>
                <DatePicker x:Name="BirthDatePicker" Margin="0,0,0,20"/>

                <Label Content="Gender"/>
                <TextBox x:Name="GenderTextBox" Margin="0,0,0,10"/>

                <!-- Register Button -->
                <Button Content="Register"
                        Height="40"
                        Margin="0,10,0,0"
                        Background="#FFF9A825"
                        Foreground="Black"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="RegisterButton_Click"/>

                <!-- Back Button -->
                <Button Content="Back"
                        Height="40"
                        Margin="0,10,0,0"
                        Background="#FFF9A825"
                        Foreground="Black"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BackButton_Click"/>

                <TextBlock x:Name="ErrorMessageTextBlock"
                           Foreground="Red"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>


    </Grid>
</Window>
