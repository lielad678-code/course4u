<Page x:Class="Course4UWpf.StudentListWithUserControlPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Course4UWpf"
      mc:Ignorable="d"
      Title="Student List">

    <Grid Background="#F5F5F5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.ColumnSpan="2">
            <Border Padding="10">
                <!-- Columns="3" = 3 כרטיסים בשורה -->
                <UniformGrid x:Name="gridUsers"
                             Columns="3"
                             VerticalAlignment="Top" />
            </Border>
        </ScrollViewer>
    </Grid>
</Page>
