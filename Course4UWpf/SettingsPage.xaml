<Page x:Class="Course4UWpf.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d"
      Title="SettingsPage"
      FontFamily="Segoe UI">

    <!-- 🎨 COLORS & STYLES (MATCH REGISTER WINDOW) -->
    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#FFFBC02D"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FFFFF176"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#FFFFFDE7"/>
        <SolidColorBrush x:Key="CardBrush" Color="White"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#333"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#666"/>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="#FFFFF9C4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="MinHeight" Value="40"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40" Width="450">

                <!-- HEADER -->
                <TextBlock Text="Account Settings"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"/>

                <TextBlock Text="Manage your profile and account details"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondary}"
                           Margin="0,5,0,30"/>

                <!-- PERSONAL INFO -->
                <Border Background="{StaticResource CardBrush}"
                        CornerRadius="12"
                        Padding="30"
                        Margin="0,0,0,25">
                    <StackPanel>
                        <TextBlock Text="Personal Information"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,20"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="First Name" Foreground="{StaticResource TextSecondary}"/><!-- check textsecondary -->
                                <TextBox x:Name="txtFirstName" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Last Name" Foreground="{StaticResource TextSecondary}"/>
                                <TextBox x:Name="txtLastName" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Email Address" Margin="0,20,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="txtEmail" />

                        <TextBlock Text="Phone number" Margin="0,20,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="txtPhoneNumber"/>

                        <TextBlock Text="Birth date" Margin="0,20,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <DatePicker x:Name="dtpickBirthdate"/>
                    </StackPanel>
                </Border>

                <!-- SECURITY -->
                <Border Background="{StaticResource CardBrush}"
                        CornerRadius="12"
                        Padding="30"
                        Margin="0,0,0,25">
                    <StackPanel>
                        <TextBlock Text="Security"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Password" Foreground="{StaticResource TextSecondary}"/>
                        <PasswordBox x:Name="txtPassword"
                                     Background="White"
                                     BorderBrush="#FFFFF9C4"
                                     BorderThickness="1"
                                     Padding="10"
                                     MinHeight="40"/>

                        <TextBlock Text="Leave blank to keep current password"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="ErrorMessageTextBlock" Foreground="#D9534F" Margin="0,6,0,0" FontWeight="SemiBold"/>
                <!-- ACTION BUTTONS -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,20,0,0">

                    <Button x:Name="btnCancel"
                            Content="Cancel"
                            Width="120"
                            Margin="0,0,15,0"
                            Background="#DDDDDD"
                            Click="btnCancel_Click"/>

                    <Button x:Name="btnSave"
                            Content="Save Changes"
                            Width="160"
                            Background="{StaticResource PrimaryBrush}"
                            Click="btnSave_Click"/>
                </StackPanel>

                
            </StackPanel>
        </ScrollViewer>
        <Frame x:Name="MainFrame"
        NavigationUIVisibility="Hidden"/>

    </Grid>
</Page>
